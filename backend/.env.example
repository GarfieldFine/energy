# 任选其一配置后保存为 .env（勿提交仓库）

# ========== 阿里云百炼 · 通义千问（推荐国内）==========
# 控制台：https://bailian.console.aliyun.com  → API-KEY
# 仅需 API + 模型名，无需自建/部署模型；模型名须与百炼文档一致。
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
# 模型名以百炼文档为准，例如：
LLM_MODEL=qwen-turbo
# LLM_MODEL=qwen-plus
# LLM_MODEL=qwen-max

# 国际地域可改用（见阿里云文档）：
# LLM_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

LLM_TIMEOUT_SEC=120

# ========== Langchain-Chatchat（远程 HTTP API，本后端转发免浏览器跨域）==========
# 勿以斜杠结尾；端口须与队友 Chatchat API 一致（常见 7861，若队友改过则跟其 CHATCHAT_API_PORT）。
# 联调前在你电脑上测：ping 队友IP → 浏览器打开 http://队友IP:端口/docs
#
# 同 Wi‑Fi / 同网段（常见）：
# CHATCHAT_BASE_URL=http://10.200.16.101:7861
#
# 仅能通过 Radmin VPN 互通时（两人同一 Radmin 网络）：
# CHATCHAT_BASE_URL=http://26.200.152.243:7861
#
# CHATCHAT_TIMEOUT_SEC=180

# ========== 本地 Ollama ==========
# LLM_API_BASE=http://127.0.0.1:11434/v1
# LLM_API_KEY=
# LLM_MODEL=qwen2.5:7b

# ========== 视觉 YOLO-World（可选）==========
# 优先 backend/yolov8x-worldv2.pt；也可指定其它权重路径。
# YOLO_WORLD_MODEL=yolov8x-worldv2.pt
# 推理精度/速度（可被上传接口 query 参数 iou、imgsz 覆盖）
# YOLO_WORLD_IMGSZ=1280
# YOLO_WORLD_IOU=0.42
# YOLO_WORLD_MAX_DET=250
# 测试时增强（TTA，明显更慢，有时能抬一点精度）
# YOLO_WORLD_AUGMENT=0
# 设为 1 跳过「零检出时提高 imgsz 再试」的第四轮重试
# YOLO_WORLD_SKIP_HIGH_RES_RETRY=0
# 设为 1 关闭「台灯下误检 book → lamp base」几何纠错（默认开启纠错）
# YOLO_WORLD_SKIP_BOOK_REFINE=1

# ========== 百度智能云 · 语音识别（智能问答页语音输入）==========
# 控制台：https://console.bce.baidu.com/ai/#/ai/speech/overview/index
# 创建「语音技术」应用后获取 AppID、API Key、Secret Key
# BAIDU_SPEECH_APP_ID=
# BAIDU_SPEECH_API_KEY=
# BAIDU_SPEECH_SECRET_KEY=
# 识别模型：1537=普通话（默认）；1737=英语；1637=粤语；1837=四川话
# BAIDU_SPEECH_DEV_PID=1537
# BAIDU_SPEECH_TIMEOUT_SEC=30

# ========== 实习版 · 轻量登录（默认开启）==========
# 比赛专用副本可设 AUTH_ENABLED=false 关闭鉴权
# AUTH_ENABLED=true
# AUTH_SECRET=请改为随机字符串
# AUTH_TOKEN_HOURS=24
# AUTH_ADMIN_PASSWORD=admin123
# AUTH_ENERGY_PASSWORD=energy123
# AUTH_OPS_PASSWORD=ops123
